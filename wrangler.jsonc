{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kyter-website",
  "compatibility_date": "2026-04-20",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "kyter.com", "custom_domain": true },
    { "pattern": "www.kyter.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
