---
const projects = [
  {
    name: "simalytics-ios",
    tagline: "Native SwiftUI iOS companion for Simkl.",
    language: "Swift",
    href: "https://github.com/Kyter-com/simalytics-ios",
  },
  {
    name: "simalytics-api",
    tagline: "Cloudflare Workers backend powering Simalytics.",
    language: "TypeScript",
    href: "https://github.com/Kyter-com/simalytics-api",
  },
];
---

<section id="projects" class="relative border-t border-[color:var(--color-tan-400)]/40 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-[color:var(--color-ink)] sm:text-4xl">
          More from Kyter
        </h2>
        <p class="mt-2 text-[color:var(--color-tan-600)]">Infrastructure and tools we maintain in the open.</p>
      </div>
      <a
        href="https://github.com/Kyter-com"
        target="_blank"
        rel="noopener"
        class="hidden text-sm text-[color:var(--color-tan-600)] transition-colors hover:text-[color:var(--color-ink)] sm:inline"
      >
        See all on GitHub →
      </a>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        projects.map((p) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener"
            class="group relative overflow-hidden rounded-2xl border border-[color:var(--color-tan-400)]/50 bg-[color:var(--color-tan-100)] p-6 transition-all hover:border-[color:var(--color-ink)]/30 hover:bg-[color:var(--color-tan-50)]"
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-sm text-[color:var(--color-ink)]">{p.name}</span>
              <span class="rounded-full border border-[color:var(--color-tan-400)] bg-[color:var(--color-tan-200)] px-2 py-0.5 text-xs text-[color:var(--color-tan-600)]">
                {p.language}
              </span>
            </div>
            <p class="mt-3 text-[color:var(--color-tan-600)]">{p.tagline}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-xs text-[color:var(--color-tan-600)] transition-colors group-hover:text-[color:var(--color-ink)]">
              View repository →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
