---
const projects = [
  {
    name: "simalytics-api",
    tagline: "TypeScript backend powering Simalytics.",
    language: "TypeScript",
    href: "https://github.com/Kyter-com/simalytics-api",
  },
];
---

<section id="projects" class="relative border-t border-zinc-900 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">More from Kyter</h2>
        <p class="mt-2 text-zinc-400">Infrastructure and tools we maintain in the open.</p>
      </div>
      <a
        href="https://github.com/Kyter-com"
        target="_blank"
        rel="noopener"
        class="hidden text-sm text-zinc-400 transition-colors hover:text-zinc-100 sm:inline"
      >
        See all on GitHub →
      </a>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        projects.map((p) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener"
            class="group relative overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-900/30 p-6 transition-all hover:border-zinc-700 hover:bg-zinc-900/60"
          >
            <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-purple-500/50 to-transparent opacity-0 transition-opacity group-hover:opacity-100" />
            <div class="flex items-center justify-between">
              <span class="font-mono text-sm text-zinc-300">{p.name}</span>
              <span class="rounded-full border border-zinc-800 bg-zinc-950 px-2 py-0.5 text-xs text-zinc-500">
                {p.language}
              </span>
            </div>
            <p class="mt-3 text-zinc-400">{p.tagline}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-xs text-zinc-500 transition-colors group-hover:text-purple-400">
              View repository →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
