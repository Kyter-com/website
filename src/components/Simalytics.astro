---
const features = [
  {
    title: "Sync with Simkl",
    body: "Your watchlists, progress, and ratings stay in sync across devices.",
  },
  {
    title: "Movies, TV & anime",
    body: "One sleek home for everything you watch — no switching apps.",
  },
  {
    title: "Up next, always",
    body: "See what to watch next, get episode reminders, and never lose your place.",
  },
  {
    title: "Native, private, fast",
    body: "Built in SwiftUI. No trackers, no ads, no telemetry you didn't opt into.",
  },
];
---

<section id="simalytics" class="relative border-t border-zinc-900 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <div class="flex justify-center md:justify-start">
        <div class="relative">
          <div
            class="absolute -inset-10 rounded-full bg-gradient-to-br from-purple-500/30 via-fuchsia-500/20 to-transparent blur-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/simalytics-icon.png"
            alt="Simalytics app icon"
            width="220"
            height="220"
            class="relative h-52 w-52 rounded-[44px] shadow-2xl shadow-purple-900/40 ring-1 ring-white/10"
          />
        </div>
      </div>

      <div>
        <p class="text-sm font-medium tracking-wide text-purple-400 uppercase">Featured app</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-white sm:text-5xl">Simalytics</h2>
        <p class="mt-4 text-lg text-zinc-400">
          Your companion for Simkl — track movies, TV shows, and anime in one place. Browse your watchlists,
          discover new titles, and keep up with your next episodes, all from a sleek, intuitive app.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://apps.apple.com/us/app/simalytics/id6745519450"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-xl bg-white px-4 py-3 text-sm font-medium text-zinc-900 transition-transform hover:scale-[1.02]"
          >
            <svg viewBox="0 0 384 512" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path
                d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
              ></path>
            </svg>
            Download on the App Store
          </a>
          <a
            href="https://github.com/Kyter-com/simalytics-ios"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-xl border border-zinc-800 bg-zinc-900/40 px-4 py-3 text-sm font-medium text-zinc-200 transition-colors hover:border-zinc-700 hover:bg-zinc-900"
          >
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              ></path>
            </svg>
            Source on GitHub
          </a>
        </div>
      </div>
    </div>

    <ul class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f) => (
          <li class="rounded-2xl border border-zinc-900 bg-zinc-900/30 p-5 transition-colors hover:border-zinc-800 hover:bg-zinc-900/60">
            <h3 class="font-medium text-white">{f.title}</h3>
            <p class="mt-2 text-sm text-zinc-400">{f.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
