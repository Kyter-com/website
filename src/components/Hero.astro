  <div class="relative mx-auto max-w-5xl px-6">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-tan-400)]/60 bg-[color:var(--color-tan-100)]/70 px-3 py-1 text-xs font-medium text-[color:var(--color-tan-600)]"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[color:var(--color-ink)] opacity-50"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-[color:var(--color-ink)]"></span>
      </span>
      Simalytics is live on the App Store
    </span>

    <h1
      class="mt-6 max-w-3xl text-5xl font-semibold tracking-tight text-[color:var(--color-ink)] sm:text-6xl md:text-7xl"
    >
      Small studio.<br /><span class="text-[color:var(--color-tan-600)]">Serious craft.</span>
    </h1>

    <p class="mt-6 max-w-xl text-lg text-[color:var(--color-tan-600)]">
      Kyter builds native apps and open tools. Home of Simalytics — a sleek companion for Simkl —
      plus a handful of things we ship and maintain in the open.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href="#simalytics"
        class="group inline-flex items-center gap-2 rounded-full bg-[color:var(--color-ink)] px-5 py-2.5 text-sm font-medium text-[color:var(--color-tan-100)] transition-transform hover:scale-[1.02]"
      >
        Meet Simalytics
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform group-hover:translate-x-0.5">
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
