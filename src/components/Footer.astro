---
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-tan-400)]/40">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-[color:var(--color-tan-600)] sm:flex-row">
    <p>© {year} Kyter, LLC</p>
    <div class="flex flex-wrap items-center justify-center gap-5">
      <a href="/simalytics/privacy.html" class="transition-colors hover:text-[color:var(--color-ink)]">Privacy</a>
      <a href="/simalytics/terms.html" class="transition-colors hover:text-[color:var(--color-ink)]">Terms</a>
      <a
        href="https://github.com/Kyter-com"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-[color:var(--color-ink)]"
      >
        GitHub
      </a>
      <a href="mailto:nick@kyter.com" class="transition-colors hover:text-[color:var(--color-ink)]">Contact</a>
    </div>
  </div>
</footer>
