---
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-900">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-zinc-500 sm:flex-row">
    <p>© {year} Kyter. Built with Astro.</p>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/Kyter-com"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-zinc-200"
      >
        GitHub
      </a>
      <a href="mailto:hello@kyter.com" class="transition-colors hover:text-zinc-200">Contact</a>
    </div>
  </div>
</footer>
